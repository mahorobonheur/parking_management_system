# Optional: copy this file to ".env" in the repo root to override Docker Compose defaults.
# docker compose automatically loads .env when present.

# SQL Server sa password (must meet SQL Server complexity rules).
MSSQL_SA_PASSWORD=Dev_Docker_Sql123!

# Host port mapped to SQL Server (default 14333 avoids clashing with a local SQL instance).
# SQL_HOST_PORT=14333

# Host port for the API (default 5000 matches local Vite proxy defaults).
# API_HOST_PORT=5000

# JWT signing secret — at least 32 characters (see Options/JwtOptions.cs).
JWT_SECRET=DockerDevelopmentSecret_ChangeMe_AtLeast32CharsLong!!
